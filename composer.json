{
    "name": "tavp/tavpkit",
    "description": "TAVPkit — starter kits and bundles for TAVP (teams, api, profile, 2fa).",
    "type": "tavpkit-module",
    "license": "MIT",
    "require": { "php": ">=8.1" },
    "require-dev": { "phpunit/phpunit": "^10.0" },
    "autoload": { "psr-4": { "Tavp\\Kit\\": "src/" } },
    "autoload-dev": { "psr-4": { "Tavp\\Kit\\Tests\\": "tests/" } },
    "config": { "sort-packages": true, "allow-plugins": {} }
}
